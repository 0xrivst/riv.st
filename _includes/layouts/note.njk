---
layout: layouts/root.njk
---

{% from 'macros/unwrap_list.njk' import unwrap_list %}

<h1>{{ title }}</h1>
<div class="post-timestamps">
    <p>Created:
        <time>{{ page.date | post_date }}</time>
    </p>
    {% if page.updated %}
    <p>
        Updated:
        <time>{{ page.updated | post_date }}</time>
    </p>
    {% endif %}
</div>
<div class="post-tags">
    <strong>Tags:</strong>
    {{ unwrap_list(tags | exclude("note")) }}
</div>

<hr />
<main>
    <article class="line">
        {{ content | safe }}
    </article>
</main>